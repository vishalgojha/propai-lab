#!/usr/bin/env bash
set -euo pipefail

PROPAI_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_FILE="/tmp/propai.log"

usage() {
  cat <<EOF
Usage: propai <command>

Commands:
  waba    Open WhatsApp onboarding to connect your market
  lab     Open PropAI Lab admin dashboard
  status  Show running services
  key     Show current API key
  help    Show this help

EOF
}

log() { echo "[propai] $*" | tee -a "$LOG_FILE"; }

ensure_key() {
  local key_file="$PROPAI_DIR/.api_key"
  if [ ! -f "$key_file" ]; then
    log "Generating API key..."
    if command -v uuidgen &>/dev/null; then
      uuidgen > "$key_file"
    else
      python3 -c "import uuid; print(uuid.uuid4())" > "$key_file"
    fi
  fi
  export AUTHENTICATION_API_KEY
  AUTHENTICATION_API_KEY=$(cat "$key_file")
}

start_lab_api() {
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    log "Lab API already running"
    return 0
  fi
  log "Starting Lab API..."
  cd "$PROPAI_DIR"
  setsid python3 -m uvicorn app:app --host 0.0.0.0 --port 8000 &>/tmp/lab-api.log &
  disown
  sleep 3
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    log "Lab API ready at http://localhost:8000"
  else
    log "ERROR: Lab API failed to start"
    cat /tmp/lab-api.log | tail -5
    return 1
  fi
}

start_docker() {
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "evolution"; then
    log "Evolution API already running"
    return 0
  fi
  log "Starting Evolution API + PostgreSQL..."
  docker compose -f "$PROPAI_DIR/docker-compose.yml" up -d 2>&1 | tee -a "$LOG_FILE"
  log "Waiting for Evolution API..."
  for i in $(seq 1 30); do
    if curl -sf http://localhost:8080/manager >/dev/null 2>&1; then
      log "Evolution API ready"
      return 0
    fi
    sleep 2
  done
  log "WARNING: Evolution API did not become ready"
  return 1
}

ensure_instance() {
  local key="$AUTHENTICATION_API_KEY"
  local instance="propai-scraper"
  local exists
  exists=$(curl -sf "http://localhost:8080/instance/connectionState/$instance" \
    -H "apikey: $key" 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('instance', {}).get('state', ''))
" 2>/dev/null || echo "")
  if [ -z "$exists" ]; then
    log "Creating WhatsApp instance..."
    curl -sf -X POST http://localhost:8080/instance/create \
      -H "Content-Type: application/json" \
      -H "apikey: $key" \
      -d '{"instanceName": "'"$instance"'", "integration": "WHATSAPP-BAILEYS"}' >/dev/null 2>&1 || true
    log "Connecting instance..."
    curl -sf "http://localhost:8080/instance/connect/$instance" \
      -H "apikey: $key" -o /dev/null 2>/dev/null || true
  fi
}

open_browser() {
  local url="$1"
  log "Opening $url"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$url" 2>/dev/null || true
  elif command -v open &>/dev/null; then
    open "$url" 2>/dev/null || true
  elif command -v sensible-browser &>/dev/null; then
    sensible-browser "$url" 2>/dev/null || true
  else
    log "No browser launcher. Open manually:"
  fi
  echo "  \u2192 $url"
}

status() {
  echo "\u2500\u2500 PropAI Services \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500"
  echo ""
  if curl -sf http://localhost:8080/manager >/dev/null 2>&1; then
    echo "  Evolution API    \u2713  http://localhost:8080"
  else
    echo "  Evolution API    \u2717  (not running)"
  fi
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    echo "  Lab API          \u2713  http://localhost:8000"
    echo "  Onboarding       \u2192  http://localhost:8000/connect"
  else
    echo "  Lab API          \u2717  (not running)"
  fi
  if [ -f "$PROPAI_DIR/.api_key" ]; then
    echo "  API key          \u25cf  $(cat "$PROPAI_DIR/.api_key" | head -c 8)\u2026"
  fi
  echo ""
}

case "${1:-help}" in
  waba)
    echo ""
    ensure_key
    start_docker
    start_lab_api
    ensure_instance
    echo ""
    open_browser "http://localhost:8000/connect"
    echo ""
    echo "  Scan the QR code with WhatsApp on your phone."
    echo "  Once connected, you'll be taken to the dashboard."
    echo ""
    ;;
  lab)
    start_lab_api
    open_browser "http://localhost:8000/"
    ;;
  key)
    ensure_key
    echo "$AUTHENTICATION_API_KEY"
    ;;
  status)
    status
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac

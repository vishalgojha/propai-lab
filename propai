#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$PWD/requirements.txt" ] && [ -f "$PWD/app.py" ] && [ -d "$PWD/frontend" ]; then
  PROPAI_DIR="$PWD"
else
  PROPAI_DIR="$SCRIPT_DIR"
fi
LOG_FILE="/tmp/propai.log"
PROPAI_VENV="$PROPAI_DIR/.venv"

log() { echo "[propai] $*" | tee -a "$LOG_FILE" >&2; }
http_ok() { curl --max-time 2 -sf "$1" >/dev/null 2>&1; }
http_get() { curl --max-time 2 -sf "$1"; }

# ── Helpers ───────────────────────────────────────────────────────

python_cmd() {
  if [ -x "$PROPAI_VENV/bin/python" ]; then
    echo "$PROPAI_VENV/bin/python"
  else
    echo "python3"
  fi
}

ensure_key() {
  local key_file="$PROPAI_DIR/.api_key"
  if [ ! -f "$key_file" ]; then
    log "Generating API key..."
    if command -v uuidgen &>/dev/null; then
      uuidgen > "$key_file"
    else
      python3 -c "import uuid; print(uuid.uuid4())" > "$key_file"
    fi
  fi
  export AUTHENTICATION_API_KEY
  AUTHENTICATION_API_KEY=$(cat "$key_file")
}

start_lab_api() {
  if http_ok http://localhost:8000/health; then
    return 0
  fi
  log "Starting PropAI server..."
  cd "$PROPAI_DIR"
  local py
  py="$(python_cmd)"
  setsid "$py" -m uvicorn app:app --host 0.0.0.0 --port 8000 &>/tmp/lab-api.log &
  disown
  sleep 3
  if http_ok http://localhost:8000/health; then
    log "Server ready at http://localhost:8000"
  else
    log "ERROR: Server failed to start"
    tail -5 /tmp/lab-api.log >&2
    return 1
  fi
}

start_frontend() {
  if http_ok http://localhost:3000/; then
    return 0
  fi
  if [ ! -d "$PROPAI_DIR/frontend/node_modules" ]; then
    log "Frontend dependencies missing. Run: propai install"
    return 1
  fi
  log "Starting PropAI frontend..."
  cd "$PROPAI_DIR/frontend"
  setsid npm run dev -- --webpack --hostname 0.0.0.0 --port 3000 &>/tmp/propai-frontend.log &
  disown
  for i in $(seq 1 20); do
    if http_ok http://localhost:3000/; then
      log "Frontend ready at http://localhost:3000"
      return 0
    fi
    sleep 1
  done
  log "WARNING: Frontend did not become ready"
  tail -5 /tmp/propai-frontend.log >&2 || true
  return 1
}

run_baileys() {
  local dir="$PROPAI_DIR/services/baileys-ingestor"
  if [ ! -d "$dir/node_modules" ]; then
    log "Baileys dependencies missing. Run: propai install"
    return 1
  fi
  if [ ! -f "$dir/.env" ]; then
    cp "$dir/.env.example" "$dir/.env"
  fi
  log "Starting Baileys WhatsApp ingestor..."
  cd "$dir"
  npm run dev
}

baileys_running() {
  pgrep -af "services/baileys-ingestor|tsx src/index.ts|node.*baileys" >/dev/null 2>&1
}

start_baileys_background() {
  local dir="$PROPAI_DIR/services/baileys-ingestor"
  if [ ! -d "$dir/node_modules" ]; then
    log "Baileys dependencies missing. Run: propai install"
    return 1
  fi
  if [ ! -f "$dir/.env" ]; then
    cp "$dir/.env.example" "$dir/.env"
  fi
  if baileys_running; then
    log "Baileys ingestor already running"
    return 0
  fi
  log "Starting Baileys ingestor in background..."
  cd "$dir"
  setsid npm run dev &>/tmp/propai-baileys.log &
  disown
  sleep 2
  if baileys_running; then
    log "Baileys log: /tmp/propai-baileys.log"
    return 0
  fi
  log "ERROR: Baileys failed to start"
  tail -20 /tmp/propai-baileys.log >&2 || true
  return 1
}

cmd_qr() {
  ensure_key
  cmd_connect
}

whatsapp_connected() {
  if ! http_ok http://localhost:8000/api/sync/connection; then
    return 1
  fi
  local connected
  connected=$(http_get http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null || true)
  [ "$connected" = "True" ] || [ "$connected" = "true" ]
}

cmd_install() {
  echo ""
  echo "  ── PropAI Installer ───────────────────"
  echo ""

  if ! command -v python3 >/dev/null 2>&1; then
    echo "  ✗ python3 is required"
    return 1
  fi
  if ! command -v npm >/dev/null 2>&1; then
    echo "  ✗ npm is required"
    return 1
  fi

  echo "  Creating local Python environment..."
  if ! python3 -m venv "$PROPAI_VENV" >/dev/null 2>&1; then
    echo "  ✗ python3-venv is required"
    echo "    Install it with: sudo apt install python3-venv"
    return 1
  fi
  local py
  py="$PROPAI_VENV/bin/python"

  echo "  Installing Python dependencies..."
  "$py" -m pip install --upgrade pip setuptools wheel >/dev/null
  "$py" -m pip install -r "$PROPAI_DIR/requirements.txt"

  echo ""
  echo "  Installing frontend dependencies..."
  npm --prefix "$PROPAI_DIR/frontend" install

  echo ""
  echo "  Installing Baileys ingestor dependencies..."
  npm --prefix "$PROPAI_DIR/services/baileys-ingestor" install

  if [ ! -f "$PROPAI_DIR/services/baileys-ingestor/.env" ]; then
    cp "$PROPAI_DIR/services/baileys-ingestor/.env.example" "$PROPAI_DIR/services/baileys-ingestor/.env"
  fi
  ensure_key

  echo ""
  echo "  ✓ PropAI installed"
  echo ""
  echo "  Next:"
  echo "    propai qr"
  echo ""
}

open_browser() {
  local url="$1"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$url" 2>/dev/null || true
  elif command -v open &>/dev/null; then
    open "$url" 2>/dev/null || true
  elif command -v sensible-browser &>/dev/null; then
    sensible-browser "$url" 2>/dev/null || true
  fi
  echo "  → $url"
}

# ── Commands ──────────────────────────────────────────────────────

cmd_connect() {
  echo ""
  ensure_key
  start_lab_api
  start_frontend
  if whatsapp_connected; then
    start_baileys_background || true
    echo ""
    echo "  ┌──────────────────────────────────────────────┐"
    echo "  │  WhatsApp is already connected.             │"
    echo "  └──────────────────────────────────────────────┘"
    echo ""
    echo "  Dashboard: http://localhost:3000"
    echo "  Connection Center: http://localhost:3000/connections"
    echo ""
    return 0
  fi
  echo ""
  echo "  ┌──────────────────────────────────────────────┐"
  echo "  │  Scan the Baileys QR code with WhatsApp.      │"
  echo "  └──────────────────────────────────────────────┘"
  echo ""
  echo "  Dashboard: http://localhost:3000"
  echo ""
  run_baileys
}

cmd_dashboard() {
  start_lab_api
  start_frontend
  echo ""
  open_browser "http://localhost:3000/"
  echo ""
}

cmd_start() {
  ensure_key
  start_lab_api
  start_frontend
  start_baileys_background
  echo ""
  echo "  PropAI running:"
  echo "  → http://localhost:3000"
  echo "  → Baileys log: /tmp/propai-baileys.log"
  echo ""
}

cmd_sync() {
  echo ""
  echo "  Historical sync is not enabled by default."
  echo "  For deterministic backfill, import WhatsApp chat exports."
  echo "  For opportunistic Baileys history capture, set PROPAI_CAPTURE_HISTORY_SYNC=true"
  echo "  in services/baileys-ingestor/.env before running 'propai connect'."
  echo ""
}

cmd_reindex() {
  local py
  py="$(python_cmd)"
  cd "$PROPAI_DIR"
  "$py" "$PROPAI_DIR/scripts/reindex_raw_messages.py" "$@"
}

cmd_memory() {
  local py
  py="$(python_cmd)"
  cd "$PROPAI_DIR"
  "$py" - <<'PY'
from config import DB_PATH
from lab.storage import SqliteStorage
storage = SqliteStorage(DB_PATH)
storage.init_schema()
print(storage.rebuild_jid_memory())
PY
}

cmd_doctor() {
  echo ""
  echo "  ── PropAI Health Check ───────────────────"
  echo ""
  local all_ok=true

  # Lab API
  if http_ok http://localhost:8000/health; then
    echo "  ✓ PropAI server"
  else
    echo "  ✗ PropAI server  (not running)"
    all_ok=false
  fi

  # Frontend
  if http_ok http://localhost:3000/; then
    echo "  ✓ PropAI frontend"
  else
    echo "  ✗ PropAI frontend  (run 'propai dashboard')"
    all_ok=false
  fi

  # Baileys ingestor
  if [ -d "$PROPAI_DIR/services/baileys-ingestor/node_modules" ]; then
    echo "  ✓ Baileys dependencies"
  else
    echo "  ✗ Baileys dependencies  (run: cd services/baileys-ingestor && npm install)"
    all_ok=false
  fi

  # API key
  if [ -f "$PROPAI_DIR/.api_key" ]; then
    echo "  ✓ API key"
  else
    echo "  ✗ API key  (will be auto-generated)"
  fi

  # WhatsApp connection
  if http_ok http://localhost:8000/api/sync/connection; then
    local connected
    connected=$(http_get http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null || true)
    if [ "$connected" = "True" ]; then
      echo "  ✓ WhatsApp connected"
    else
      echo "  ✗ WhatsApp disconnected  (run 'propai connect')"
    fi
  fi

  # Python deps
  local py
  py="$(python_cmd)"
  if "$py" -c "import fastapi, uvicorn, httpx" 2>/dev/null; then
    echo "  ✓ Python dependencies"
  else
    echo "  ✗ Python dependencies  (run 'propai install')"
    all_ok=false
  fi

  # Registry / storage
  if [ -f "$PROPAI_DIR/lab.db" ]; then
    local db_size
    db_size=$(du -h "$PROPAI_DIR/lab.db" 2>/dev/null | cut -f1)
    echo "  ✓ Storage  ($db_size)"
  else
    echo "  – Storage  (not initialized)"
  fi

  # Internet
  if http_ok https://web.whatsapp.com; then
    echo "  ✓ Internet"
  else
    echo "  ✗ Internet  (check your connection)"
    all_ok=false
  fi

  echo ""
  if $all_ok; then
    echo "  Everything looks good."
  else
    echo "  Some checks failed. Run 'propai qr' or 'propai dashboard' to fix."
  fi
  echo ""
}

cmd_status() {
  echo ""
  echo "  ── PropAI Status ─────────────────────"
  echo ""
  local baileys_live=false
  if baileys_running; then
    baileys_live=true
  fi
  if http_ok http://localhost:8000/health; then
    echo "  Server       ✓  http://localhost:8000"
  else
    echo "  Server       ✗  (not running)"
  fi
  if http_ok http://localhost:3000/; then
    echo "  Frontend     ✓  http://localhost:3000"
  else
    echo "  Frontend     ✗  (not running)"
  fi
  if http_ok http://localhost:8000/api/sync/connection; then
    local connected
    connected=$(http_get http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null || true)
    if [ "$connected" = "True" ]; then
      echo "  WhatsApp     ✓  Connected"
    else
      echo "  WhatsApp     –  Disconnected"
    fi
  elif [ -f "$PROPAI_DIR/services/baileys-ingestor/auth/status.json" ]; then
    local connected
    connected=$("$(python_cmd)" -c "import json; print(json.load(open('$PROPAI_DIR/services/baileys-ingestor/auth/status.json')).get('connected', False))" 2>/dev/null || true)
    if { [ "$connected" = "True" ] || [ "$connected" = "true" ]; } && $baileys_live; then
      echo "  WhatsApp     ✓  Connected (Baileys status file)"
    elif [ "$connected" = "True" ] || [ "$connected" = "true" ]; then
      echo "  WhatsApp     –  Last known connected, ingestor not running"
    else
      echo "  WhatsApp     –  Disconnected"
    fi
  fi
  if $baileys_live; then
    echo "  Baileys      ✓  Running"
  else
    echo "  Baileys      –  Not running"
  fi
  if [ -f "$PROPAI_DIR/.api_key" ]; then
    local key_preview
    key_preview=$(head -c 8 "$PROPAI_DIR/.api_key")
    echo "  API key      ●  ${key_preview}…"
  fi
  echo ""
}

cmd_key() {
  ensure_key
  echo "$AUTHENTICATION_API_KEY"
}

cmd_menu() {
  echo ""
  echo "  ════════════════════════════════════════"
  echo ""
  echo "          PropAI"
  echo "  AI Operating System for Realtors"
  echo ""
  echo "  ════════════════════════════════════════"
  echo ""

  # Show live status
  if http_ok http://localhost:8000/api/sync/connection; then
    local connected
    connected=$(http_get http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null || true)
    if [ "$connected" = "True" ]; then
      echo "  ✓ WhatsApp Connected"
    else
      echo "  ✓ Engine running"
      echo "  – WhatsApp disconnected"
    fi
  else
    echo "  – Offline  (run 'propai qr')"
  fi
  echo ""

  # Available commands
  echo "  1. Connect WhatsApp"
  echo "  2. Historical Sync"
  echo "  3. Live Market"
  echo "  4. Dashboard"
  echo "  5. Health Check"
  echo "  6. Settings"
  echo ""
  echo "  propai <command>  or  select a number"
  echo ""
}

usage() {
  echo "Usage: propai <command>"
  echo ""
  echo "Commands:"
  echo "  install    Install Python, frontend, and Baileys dependencies"
  echo "  qr         Open the terminal QR / connection view"
  echo "  connect    Connect WhatsApp to PropAI with Baileys"
  echo "  start      Start API, frontend, and Baileys in background"
  echo "  dashboard  Open the PropAI dashboard"
  echo "  sync       Start historical group sync"
  echo "  reindex    Reparse old raw messages and rebuild listings"
  echo "  memory     Rebuild JID memory profiles from raw messages"
  echo "  doctor     Run health checks"
  echo "  status     Show running services"
  echo "  key        Show API key"
  echo "  help       Show this help"
}

# ── Dispatch ──────────────────────────────────────────────────────

case "${1:-}" in
  install|setup)
    cmd_install
    ;;
  qr)
    cmd_qr
    ;;
  connect)
    cmd_connect
    ;;
  start)
    cmd_start
    ;;
  waba)
    cmd_qr
    ;;
  dashboard|lab|admin)
    cmd_dashboard
    ;;
  sync)
    cmd_sync
    ;;
  reindex)
    shift
    cmd_reindex "$@"
    ;;
  memory)
    cmd_memory
    ;;
  doctor|check)
    cmd_doctor
    ;;
  status)
    cmd_status
    ;;
  key)
    cmd_key
    ;;
  help|--help|-h)
    usage
    ;;
  '')
    cmd_menu
    ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac

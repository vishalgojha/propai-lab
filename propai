#!/usr/bin/env bash
set -euo pipefail

PROPAI_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_FILE="/tmp/propai.log"

log() { echo "[propai] $*" | tee -a "$LOG_FILE" >&2; }

# ── Helpers ───────────────────────────────────────────────────────

ensure_key() {
  local key_file="$PROPAI_DIR/.api_key"
  if [ ! -f "$key_file" ]; then
    log "Generating API key..."
    if command -v uuidgen &>/dev/null; then
      uuidgen > "$key_file"
    else
      python3 -c "import uuid; print(uuid.uuid4())" > "$key_file"
    fi
  fi
  export AUTHENTICATION_API_KEY
  AUTHENTICATION_API_KEY=$(cat "$key_file")
}

start_lab_api() {
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    return 0
  fi
  log "Starting PropAI server..."
  cd "$PROPAI_DIR"
  setsid python3 -m uvicorn app:app --host 0.0.0.0 --port 8000 &>/tmp/lab-api.log &
  disown
  sleep 3
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    log "Server ready at http://localhost:8000"
  else
    log "ERROR: Server failed to start"
    tail -5 /tmp/lab-api.log >&2
    return 1
  fi
}

start_frontend() {
  if curl -sf http://localhost:3000/ >/dev/null 2>&1; then
    return 0
  fi
  log "Starting PropAI frontend..."
  cd "$PROPAI_DIR/frontend"
  setsid npm run dev -- --webpack --hostname 0.0.0.0 --port 3000 &>/tmp/propai-frontend.log &
  disown
  for i in $(seq 1 20); do
    if curl -sf http://localhost:3000/ >/dev/null 2>&1; then
      log "Frontend ready at http://localhost:3000"
      return 0
    fi
    sleep 1
  done
  log "WARNING: Frontend did not become ready"
  tail -5 /tmp/propai-frontend.log >&2 || true
  return 1
}

run_baileys() {
  local dir="$PROPAI_DIR/services/baileys-ingestor"
  if [ ! -d "$dir/node_modules" ]; then
    log "Installing Baileys ingestor dependencies..."
    (cd "$dir" && npm install)
  fi
  if [ ! -f "$dir/.env" ]; then
    cp "$dir/.env.example" "$dir/.env"
  fi
  log "Starting Baileys WhatsApp ingestor..."
  cd "$dir"
  npm run dev
}

open_browser() {
  local url="$1"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$url" 2>/dev/null || true
  elif command -v open &>/dev/null; then
    open "$url" 2>/dev/null || true
  elif command -v sensible-browser &>/dev/null; then
    sensible-browser "$url" 2>/dev/null || true
  fi
  echo "  → $url"
}

# ── Commands ──────────────────────────────────────────────────────

cmd_connect() {
  echo ""
  ensure_key
  start_lab_api
  start_frontend
  echo ""
  echo "  ┌──────────────────────────────────────────────┐"
  echo "  │  Scan the Baileys QR code with WhatsApp.      │"
  echo "  └──────────────────────────────────────────────┘"
  echo ""
  echo "  Dashboard: http://localhost:3000"
  echo ""
  run_baileys
}

cmd_dashboard() {
  start_lab_api
  start_frontend
  echo ""
  open_browser "http://localhost:3000/"
  echo ""
}

cmd_sync() {
  echo ""
  echo "  Historical sync is not enabled by default."
  echo "  For deterministic backfill, import WhatsApp chat exports."
  echo "  For opportunistic Baileys history capture, set PROPAI_CAPTURE_HISTORY_SYNC=true"
  echo "  in services/baileys-ingestor/.env before running 'propai connect'."
  echo ""
}

cmd_doctor() {
  echo ""
  echo "  ── PropAI Health Check ───────────────────"
  echo ""
  local all_ok=true

  # Lab API
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    echo "  ✓ PropAI server"
  else
    echo "  ✗ PropAI server  (not running)"
    all_ok=false
  fi

  # Frontend
  if curl -sf http://localhost:3000/ >/dev/null 2>&1; then
    echo "  ✓ PropAI frontend"
  else
    echo "  ✗ PropAI frontend  (run 'propai dashboard')"
    all_ok=false
  fi

  # Baileys ingestor
  if [ -d "$PROPAI_DIR/services/baileys-ingestor/node_modules" ]; then
    echo "  ✓ Baileys dependencies"
  else
    echo "  ✗ Baileys dependencies  (run: cd services/baileys-ingestor && npm install)"
    all_ok=false
  fi

  # API key
  if [ -f "$PROPAI_DIR/.api_key" ]; then
    echo "  ✓ API key"
  else
    echo "  ✗ API key  (will be auto-generated)"
  fi

  # WhatsApp connection
  if curl -sf http://localhost:8000/api/sync/connection >/dev/null 2>&1; then
    local connected
    connected=$(curl -sf http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null)
    if [ "$connected" = "True" ]; then
      echo "  ✓ WhatsApp connected"
    else
      echo "  ✗ WhatsApp disconnected  (run 'propai connect')"
    fi
  fi

  # Python deps
  if python3 -c "import fastapi, uvicorn, httpx" 2>/dev/null; then
    echo "  ✓ Python dependencies"
  else
    echo "  ✗ Python dependencies  (run: pip install -r requirements.txt)"
    all_ok=false
  fi

  # Registry / storage
  if [ -f "$PROPAI_DIR/lab.db" ]; then
    local db_size
    db_size=$(du -h "$PROPAI_DIR/lab.db" 2>/dev/null | cut -f1)
    echo "  ✓ Storage  ($db_size)"
  else
    echo "  – Storage  (not initialized)"
  fi

  # Internet
  if curl -sf https://web.whatsapp.com >/dev/null 2>&1; then
    echo "  ✓ Internet"
  else
    echo "  ✗ Internet  (check your connection)"
    all_ok=false
  fi

  echo ""
  if $all_ok; then
    echo "  Everything looks good."
  else
    echo "  Some checks failed. Run 'propai connect' or 'propai dashboard' to fix."
  fi
  echo ""
}

cmd_status() {
  echo ""
  echo "  ── PropAI Status ─────────────────────"
  echo ""
  if curl -sf http://localhost:8000/health >/dev/null 2>&1; then
    echo "  Server       ✓  http://localhost:8000"
  else
    echo "  Server       ✗  (not running)"
  fi
  if curl -sf http://localhost:3000/ >/dev/null 2>&1; then
    echo "  Frontend     ✓  http://localhost:3000"
  else
    echo "  Frontend     ✗  (not running)"
  fi
  if curl -sf http://localhost:8000/api/sync/connection >/dev/null 2>&1; then
    local connected
    connected=$(curl -sf http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null)
    if [ "$connected" = "True" ]; then
      echo "  WhatsApp     ✓  Connected"
    else
      echo "  WhatsApp     –  Disconnected"
    fi
  fi
  if [ -f "$PROPAI_DIR/.api_key" ]; then
    local key_preview
    key_preview=$(head -c 8 "$PROPAI_DIR/.api_key")
    echo "  API key      ●  ${key_preview}…"
  fi
  echo ""
}

cmd_key() {
  ensure_key
  echo "$AUTHENTICATION_API_KEY"
}

cmd_menu() {
  echo ""
  echo "  ════════════════════════════════════════"
  echo ""
  echo "          PropAI"
  echo "  AI Operating System for Realtors"
  echo ""
  echo "  ════════════════════════════════════════"
  echo ""

  # Show live status
  if curl -sf http://localhost:8000/api/sync/connection >/dev/null 2>&1; then
    local connected
    connected=$(curl -sf http://localhost:8000/api/sync/connection | python3 -c "import sys,json; print(json.load(sys.stdin).get('connected',False))" 2>/dev/null)
    if [ "$connected" = "True" ]; then
      echo "  ✓ WhatsApp Connected"
    else
      echo "  ✓ Engine running"
      echo "  – WhatsApp disconnected"
    fi
  else
    echo "  – Offline  (run 'propai connect')"
  fi
  echo ""

  # Available commands
  echo "  1. Connect WhatsApp"
  echo "  2. Historical Sync"
  echo "  3. Live Market"
  echo "  4. Dashboard"
  echo "  5. Health Check"
  echo "  6. Settings"
  echo ""
  echo "  propai <command>  or  select a number"
  echo ""
}

usage() {
  echo "Usage: propai <command>"
  echo ""
  echo "Commands:"
  echo "  connect    Connect WhatsApp to PropAI with Baileys"
  echo "  dashboard  Open the PropAI dashboard"
  echo "  sync       Start historical group sync"
  echo "  doctor     Run health checks"
  echo "  status     Show running services"
  echo "  key        Show API key"
  echo "  help       Show this help"
}

# ── Dispatch ──────────────────────────────────────────────────────

case "${1:-}" in
  connect|waba)
    cmd_connect
    ;;
  dashboard|lab|admin)
    cmd_dashboard
    ;;
  sync)
    cmd_sync
    ;;
  doctor|check)
    cmd_doctor
    ;;
  status)
    cmd_status
    ;;
  key)
    cmd_key
    ;;
  help|--help|-h)
    usage
    ;;
  '')
    cmd_menu
    ;;
  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac

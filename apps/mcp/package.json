{
  "name": "mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PropAI remote MCP server for real estate listings and market intelligence",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --loader ts-node/esm src/server.ts",
    "stdio": "node dist/stdio.js",
    "dev:stdio": "node --loader ts-node/esm src/stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@supabase/supabase-js": "latest",
    "dotenv": "latest",
    "express": "latest",
    "jsonwebtoken": "latest",
    "ws": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/ws": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  }
}
